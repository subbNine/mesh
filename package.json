{
  "name": "mesh",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"turbo dev\"",
    "dev:ws": "npm run ws -w apps/api",
    "build": "turbo build",
